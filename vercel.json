{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    { "src": "/actions/(.*)", "dest": "/api/actions/$1.php" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(index|dashboard|equipment|requests|admin_requests|maintenance|reports)", "dest": "/api/$1.php" },
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/(.*)", "dest": "/api/$1.php" }
  ]
}